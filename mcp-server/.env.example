# ========================================
# Silent Escalation Copilot - MCP Server
# Environment Configuration Template
# ========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control!

# ========================================
# Server Configuration
# ========================================
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ========================================
# Azure AD OAuth Configuration
# ========================================
# Get these from Azure Portal > App Registrations
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_REDIRECT_URI=https://your-app.azurewebsites.net/auth/callback

# Azure AD Authority URL
AZURE_AUTHORITY=https://login.microsoftonline.com/${AZURE_TENANT_ID}

# OAuth Scopes (comma-separated)
AZURE_SCOPES=https://graph.microsoft.com/.default

# ========================================
# Jira API Configuration
# ========================================
# Jira Cloud instance URL (e.g., https://yourcompany.atlassian.net)
JIRA_BASE_URL=https://your-company.atlassian.net

# Jira API Authentication
# Option 1: Basic Auth (email + API token)
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token-here

# Option 2: OAuth 2.0 (for production)
# JIRA_OAUTH_CLIENT_ID=your-jira-oauth-client-id
# JIRA_OAUTH_CLIENT_SECRET=your-jira-oauth-secret

# Jira Project Keys to monitor (comma-separated)
JIRA_PROJECT_KEYS=PROJ1,PROJ2,PROJ3

# JQL for blocked issues
JIRA_BLOCKED_JQL=status = Blocked OR labels = blocked OR priority = Highest

# ========================================
# Microsoft Teams Configuration
# ========================================
# Teams Webhook URL for notifications
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# Teams App ID (if using Teams Bot)
TEAMS_APP_ID=your-teams-app-id
TEAMS_APP_PASSWORD=your-teams-app-password

# ========================================
# Microsoft Graph API Configuration
# ========================================
# Graph API Base URL
GRAPH_API_URL=https://graph.microsoft.com/v1.0

# Graph API Scopes for M365 data access
GRAPH_SCOPES=Mail.Read,Chat.Read,Files.Read.All,Sites.Read.All,Tasks.Read

# ========================================
# MCP Server Configuration
# ========================================
# MCP Protocol Version
MCP_VERSION=1.0

# MCP Server Name
MCP_SERVER_NAME=silent-escalation-mcp

# MCP Server Description
MCP_SERVER_DESCRIPTION=Enterprise risk detection with Jira and Teams integration

# Health check endpoint
HEALTH_CHECK_PATH=/health

# ========================================
# Caching & Performance
# ========================================
# Cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL=300

# Max concurrent API requests
MAX_CONCURRENT_REQUESTS=10

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# ========================================
# Risk Detection Configuration
# ========================================
# Keywords that indicate escalation-worthy risks
RISK_KEYWORDS=blocked,blocker,critical,urgent,escalate,delayed,overdue,frustrated

# Minimum severity level to report (CRITICAL, HIGH, MEDIUM, LOW)
MIN_SEVERITY_LEVEL=MEDIUM

# Days before considering a task overdue
OVERDUE_THRESHOLD_DAYS=3

# ========================================
# Security & Compliance
# ========================================
# Enable/disable PII redaction
ENABLE_PII_REDACTION=true

# Enable/disable audit logging
ENABLE_AUDIT_LOG=true

# Audit log destination (file, database, azure-monitor)
AUDIT_LOG_DESTINATION=azure-monitor

# Azure Application Insights (for monitoring)
APPINSIGHTS_INSTRUMENTATIONKEY=your-app-insights-key

# ========================================
# Database Configuration (Optional)
# ========================================
# For storing escalation history
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_SSL_ENABLED=true

# ========================================
# Power Platform Integration (Optional)
# ========================================
# Power Automate Flow Trigger URL
# POWER_AUTOMATE_FLOW_URL=https://prod-xx.westus.logic.azure.com:443/workflows/...

# Power BI Workspace ID
# POWERBI_WORKSPACE_ID=your-workspace-id
# POWERBI_DATASET_ID=your-dataset-id

# ========================================
# Feature Flags
# ========================================
ENABLE_JIRA_INTEGRATION=true
ENABLE_TEAMS_INTEGRATION=true
ENABLE_ADAPTIVE_CARDS=true
ENABLE_SENTIMENT_ANALYSIS=false
ENABLE_ML_PREDICTIONS=false

# ========================================
# Development / Testing
# ========================================
# Enable debug mode (verbose logging)
DEBUG=false

# Mock external APIs (for testing without real credentials)
MOCK_JIRA_API=false
MOCK_TEAMS_API=false
MOCK_GRAPH_API=false

# Test user email (for development)
TEST_USER_EMAIL=test.user@company.com
